# Datenbank-Passwort for PostgreSQL
DD_DATABASE_PASSWORD=EinSehrSicheresPasswort123! #create with: openssl rand -base64 24

# Django Secret Key (sollte ein langer, zufälliger String sein)
DD_SECRET_KEY=DeinLangerZufaelligerDjangoSecretKey_Mindestens50Zeichen #create with: openssl rand -base64 48

# AES-256 Schlüssel (muss exakt 32 Bytes bzw. Zeichen lang sein)
DD_CREDENTIAL_AES_256_KEY=Ein32ZeichenLangerZufaelligerKey! #create with: tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c 32; echo ""
